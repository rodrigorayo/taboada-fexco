---
// Combos Section - Mid brown background with angled combo cards
const combos = [
  {
    id: 'combo-familiar',
    name: 'Combo Familiar',
    emoji: '👨‍👩‍👧‍👦',
    description: 'Ideal para disfrutar en familia. Incluye trufas surtidas, galletas artesanales y pan especial.',
    image: '/images/combo_familiar.png',
    fairPrice: '75',
    normalPrice: '110',
    tag: 'Más Popular',
    tagColor: '#D4A853',
    items: ['2 bolsas de trufas', '1 caja de galletas', '2 panes artesanales'],
  },
  {
    id: 'combo-goloso',
    name: 'Combo Goloso',
    emoji: '🍫',
    description: 'Para los verdaderos amantes del chocolate. Lo mejor de nuestra selección en un solo combo.',
    image: '/images/combo_goloso.png',
    fairPrice: '45',
    normalPrice: '65',
    tag: 'Más Vendido',
    tagColor: '#C0392B',
    items: ['1 bolsa de trufas premium', '1 bolsa de galletas', '1 pastelito gourmet'],
  },
  {
    id: 'combo-regalo',
    name: 'Combo Regalo FEXCO',
    emoji: '🎁',
    description: 'El regalo perfecto para esa persona especial. Presentación premium con caja decorativa.',
    image: '/images/combo_regalo.png',
    fairPrice: '95',
    normalPrice: '140',
    tag: 'Edición Especial',
    tagColor: '#7B3F1E',
    items: ['Surtido premium de trufas', 'Galletas en presentación regalo', 'Caja decorativa FEXCO'],
  },
];
---

<section id="combos" class="relative bg-[#FDF6EC]">

  <!-- Wave top from cream -->
  <div class="overflow-hidden">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full -mb-1">
      <path d="M0 80C240 0 480 0 720 40C960 80 1200 80 1440 40V0H0V80Z" fill="#C4854A"/>
    </svg>
  </div>

  <div class="bg-[#C4854A] py-16 relative overflow-hidden">

    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-24 -right-24 w-72 h-72 rounded-full bg-white/5"></div>
      <div class="absolute bottom-0 -left-16 w-56 h-56 rounded-full bg-white/5"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">

      <!-- Section header -->
      <div class="text-center mb-14 reveal">
        <div class="inline-flex items-center gap-2 bg-white/20 text-white text-xs font-semibold px-4 py-2 rounded-full mb-4 backdrop-blur-sm">
          <span>🎪</span> Exclusivo FEXCO 2026
        </div>
        <h2 class="text-3xl lg:text-5xl font-bold text-white mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
          Combos Exclusivos <span class="text-[#3B1A0A]">FEXCO 2026</span>
        </h2>
        <p class="text-white/90 text-lg max-w-2xl mx-auto">
          Los packs perfectos para disfrutar o regalar. Precios especiales solo válidos durante la feria.
        </p>
      </div>

      <!-- Combo cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {combos.map((combo, index) => (
          <article
            class="combo-card bg-white rounded-3xl overflow-hidden shadow-xl cursor-pointer"
            id={combo.id}
          >
            <!-- Card top with image -->
            <div class="relative bg-[#FDF6EC] p-8 flex items-center justify-center h-52 overflow-hidden">
              <!-- Background circle -->
              <div class="absolute w-40 h-40 rounded-full bg-[#F5E9D4] opacity-60"></div>
              
              <!-- Tag badge -->
              <div
                class="absolute top-4 left-4 px-3 py-1 rounded-full text-white text-xs font-bold badge-shine"
                style={`background-color: ${combo.tagColor}`}
              >
                {combo.tag}
              </div>

              <img
                src={combo.image}
                alt={`${combo.name} - Combo Taboada FEXCO 2026`}
                class="relative z-10 h-36 w-auto object-contain drop-shadow-2xl hover:scale-110 transition-transform duration-500"
              />
            </div>

            <!-- Card content -->
            <div class="p-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">{combo.emoji}</span>
                <h3 class="text-xl font-bold text-[#3B1A0A]" style="font-family: 'Playfair Display', Georgia, serif;">
                  {combo.name}
                </h3>
              </div>

              <p class="text-[#7B3F1E] text-sm leading-relaxed mb-4">{combo.description}</p>

              <!-- Included items -->
              <ul class="space-y-1 mb-6">
                {combo.items.map((item) => (
                  <li class="flex items-center gap-2 text-xs text-[#3B1A0A]">
                    <svg class="w-3 h-3 text-[#D4A853] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>

              <!-- Price -->
              <div class="flex items-end justify-between mb-5">
                <div>
                  <span class="text-2xl font-bold text-[#C0392B]">Bs. {combo.fairPrice}</span>
                  <span class="block text-xs text-[#C4854A] line-through">Precio normal: Bs. {combo.normalPrice}</span>
                </div>
                <div class="bg-[#3B1A0A] text-[#D4A853] text-xs font-bold px-3 py-1 rounded-full">
                  {Math.round((1 - parseInt(combo.fairPrice) / parseInt(combo.normalPrice)) * 100)}% OFF
                </div>
              </div>

              <!-- Dual CTAs -->
              <div class="flex flex-col gap-2">
                <a
                  href="#cupones"
                  aria-label={`Usar cupón para ${combo.name}`}
                  class="flex items-center justify-center gap-2 bg-[#C0392B] hover:bg-[#96281B] text-white font-semibold py-3 px-4 rounded-xl transition-all duration-300 text-sm hover:shadow-lg"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                  </svg>
                  Usar mi Cupón
                </a>
                <button
                  aria-label={`Comprar ${combo.name}`}
                  class="flex items-center justify-center gap-2 bg-[#3B1A0A] hover:bg-[#7B3F1E] text-white font-semibold py-3 px-4 rounded-xl transition-all duration-300 text-sm"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                  </svg>
                  Comprar Combo
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Mascot trufa + CTA -->
      <div class="flex flex-col lg:flex-row items-center justify-between mt-16 gap-8 reveal delay-300">
        <div class="flex items-center gap-4">
          <img
            src="/images/trufa_smile.png"
            alt="Mascota trufa sonriente de Taboada"
            class="w-20 h-20 object-contain drop-shadow-lg animate-float"
          />
          <div class="text-white">
            <p class="font-bold text-xl" style="font-family: 'Playfair Display', Georgia, serif;">
              ¿Tienes tu cupón de WhatsApp?
            </p>
            <p class="text-white/80 text-sm">Mostralo en el stand y ¡obtén tu descuento!</p>
          </div>
        </div>
        <a
          href="#registro"
          id="combo-cta-registro"
          class="inline-flex items-center gap-2 bg-white text-[#3B1A0A] hover:bg-[#3B1A0A] hover:text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Regístrate y Recibe tu Cupón por WhatsApp
        </a>
      </div>
    </div>
  </div>

  <!-- Wave to cream footer -->
  <div class="overflow-hidden bg-[#C4854A]">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full">
      <path d="M0 0C240 80 480 80 720 40C960 0 1200 0 1440 40V80H0V0Z" fill="#3B1A0A"/>
    </svg>
  </div>
</section>

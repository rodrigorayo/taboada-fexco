---
// Location Section
---

<section id="ubicacion" class="bg-[#3B1A0A] py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center reveal">

      <!-- Left: Stand info -->
      <div class="text-white">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-0.5 bg-[#D4A853]"></div>
          <span class="text-[#D4A853] text-xs font-semibold uppercase tracking-widest">Encuéntranos</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold mb-6" style="font-family: 'Playfair Display', Georgia, serif;">
          Ubicación del Stand
        </h2>

        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-4 bg-white/10 rounded-2xl p-4 border border-white/10 backdrop-blur-sm">
            <div class="w-10 h-10 rounded-xl bg-[#D4A853] flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#3B1A0A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold">Pasillo Principal — Stand N° 42</p>
              <p class="text-white/60 text-sm">Feria FEXCO 2026 · Sector Premium Gastronómico</p>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-white/10 rounded-2xl p-4 border border-white/10 backdrop-blur-sm">
            <div class="w-10 h-10 rounded-xl bg-[#D4A853] flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#3B1A0A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold">Horario de Atención</p>
              <p class="text-white/60 text-sm">Lun–Vie: 9:00 – 18:00 · Fin de semana: 9:00 – 20:00</p>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-white/10 rounded-2xl p-4 border border-white/10 backdrop-blur-sm">
            <div class="w-10 h-10 rounded-xl bg-[#D4A853] flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#3B1A0A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold">Contacto Directo</p>
              <p class="text-white/60 text-sm">WhatsApp: +591 7XXXXXXXX</p>
            </div>
          </div>
        </div>

        <a
          href="https://maps.google.com"
          target="_blank"
          rel="noopener noreferrer"
          id="maps-link"
          class="inline-flex items-center gap-2 border-2 border-[#D4A853] text-[#D4A853] hover:bg-[#D4A853] hover:text-[#3B1A0A] font-semibold px-7 py-3 rounded-full transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          Ver en el Mapa
        </a>
      </div>

      <!-- Right: Map placeholder styled -->
      <div class="reveal delay-200">
        <div class="relative rounded-3xl overflow-hidden shadow-2xl h-72 lg:h-96 bg-gradient-to-br from-[#5C2F10] to-[#2A0D03]">
          <!-- Stylized map mockup -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center text-white/60">
              <!-- Grid lines -->
              <div class="absolute inset-0 opacity-20">
                {[...Array(8)].map((_, i) => (
                  <div
                    class="absolute top-0 bottom-0 border-l border-white/30"
                    style={`left: ${(i + 1) * 12.5}%`}
                  ></div>
                ))}
                {[...Array(6)].map((_, i) => (
                  <div
                    class="absolute left-0 right-0 border-t border-white/30"
                    style={`top: ${(i + 1) * 16.67}%`}
                  ></div>
                ))}
              </div>
              <!-- Pin -->
              <div class="relative z-10">
                <div class="w-16 h-16 rounded-full bg-[#C0392B] border-4 border-white flex items-center justify-center mx-auto mb-3 shadow-2xl animate-float">
                  <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C7.802 0 4 3.403 4 7.602 4 11.8 7.469 16.812 12 24c4.531-7.188 8-12.2 8-16.398C20 3.403 16.199 0 12 0zm0 11a3 3 0 110-6 3 3 0 010 6z"/>
                  </svg>
                </div>
                <p class="font-bold text-white text-sm">Stand Taboada · FEXCO 2026</p>
                <p class="text-white/50 text-xs">Pasillo Principal · Stand N° 42</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
// Hero Section - Full width cream background with floating products
---

<section id="hero" class="relative min-h-screen bg-[#FDF6EC] overflow-hidden flex items-center pt-20">

  <!-- Background decorative circles -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 rounded-full border-2 border-[#F5E9D4] opacity-60"></div>
    <div class="absolute top-32 left-20 w-48 h-48 rounded-full border border-[#F5E9D4] opacity-40"></div>
    <div class="absolute bottom-40 right-16 w-96 h-96 rounded-full border-2 border-[#F5E9D4] opacity-50"></div>
    <div class="absolute top-60 right-40 w-24 h-24 rounded-full bg-[#F5E9D4] opacity-30"></div>
    <!-- Gold dot accents -->
    <div class="absolute top-40 left-1/3 w-3 h-3 rounded-full bg-[#D4A853] opacity-60 animate-float-slow delay-200"></div>
    <div class="absolute bottom-60 left-1/4 w-2 h-2 rounded-full bg-[#D4A853] opacity-50 animate-float-slow delay-700"></div>
    <div class="absolute top-1/3 right-1/3 w-4 h-4 rounded-full bg-[#C4854A] opacity-30 animate-float delay-500"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 w-full">
    <div class="grid lg:grid-cols-2 gap-8 items-center min-h-[80vh]">

      <!-- Left: Text Content -->
      <div class="relative z-10 text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-[#3B1A0A] text-[#D4A853] text-xs font-semibold px-4 py-2 rounded-full mb-6 badge-shine animate-fade-in">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          FEXCO 2026 · Oferta Exclusiva de Feria
        </div>

        <!-- Main headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#3B1A0A] leading-tight mb-6 text-balance animate-slide-up" style="font-family: 'Playfair Display', Georgia, serif;">
          ¡Haz de tu visita a <span class="text-[#7B3F1E] italic">FEXCO</span> un dulce recuerdo con
          <span class="relative inline-block">
            <span class="text-[#C0392B]">Taboada!</span>
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 8" fill="none">
              <path d="M2 6C40 2 80 2 100 4C120 6 160 6 198 2" stroke="#D4A853" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="text-[#7B3F1E] text-lg mb-8 leading-relaxed max-w-lg mx-auto lg:mx-0 animate-slide-up delay-200">
          Descubre nuestros combos exclusivos y ofertas especiales de feria creados 
          solo para ti. Ingredientes artesanales, sabor inigualable.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-slide-up delay-300">
          <a
            href="#cupones"
            id="hero-cta-primary"
            class="inline-flex items-center justify-center gap-2 bg-[#C0392B] hover:bg-[#96281B] text-white font-bold px-8 py-4 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1 animate-pulse-gold"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
            </svg>
            Canjear mi Cupón Gratis
          </a>
          <a
            href="#combos"
            id="hero-cta-secondary"
            class="inline-flex items-center justify-center gap-2 border-2 border-[#7B3F1E] text-[#7B3F1E] hover:bg-[#7B3F1E] hover:text-white font-semibold px-8 py-4 rounded-full transition-all duration-300"
          >
            Ver Combos
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <!-- Stats bar -->
        <div class="flex flex-wrap gap-6 mt-10 justify-center lg:justify-start animate-slide-up delay-500">
          <div class="text-center">
            <span class="block text-2xl font-bold text-[#C0392B]">+50</span>
            <span class="text-xs text-[#C4854A] uppercase tracking-wider">Productos</span>
          </div>
          <div class="w-px bg-[#F5E9D4]"></div>
          <div class="text-center">
            <span class="block text-2xl font-bold text-[#C0392B]">15</span>
            <span class="text-xs text-[#C4854A] uppercase tracking-wider">Años de Tradición</span>
          </div>
          <div class="w-px bg-[#F5E9D4]"></div>
          <div class="text-center">
            <span class="block text-2xl font-bold text-[#C0392B]">3</span>
            <span class="text-xs text-[#C4854A] uppercase tracking-wider">Combos Exclusivos</span>
          </div>
        </div>
      </div>

      <!-- Right: Floating Product Images -->
      <div class="relative h-[500px] lg:h-[600px] flex items-center justify-center">

        <!-- Large circle background -->
        <div class="absolute w-80 h-80 lg:w-96 lg:h-96 rounded-full bg-[#F5E9D4] opacity-70"></div>

        <!-- Floating product 1 - Truffle Box -->
        <div class="absolute top-8 right-8 lg:top-12 lg:right-12 animate-float">
          <div class="relative w-52 lg:w-64">
            <img
              src="/images/hero_truffle_box.png"
              alt="Caja de trufas premium Taboada"
              class="w-full drop-shadow-2xl"
            />
            <!-- Price tag -->
            <div class="absolute -top-2 -right-2 bg-[#C0392B] text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
              ¡Oferta!
            </div>
          </div>
        </div>

        <!-- Floating product 2 - Croissant -->
        <div class="absolute bottom-12 left-4 lg:bottom-16 lg:left-8 animate-float-reverse">
          <div class="relative w-44 lg:w-52">
            <img
              src="/images/hero_croissant.png"
              alt="Pan artesanal premium Taboada"
              class="w-full drop-shadow-2xl"
            />
          </div>
        </div>

        <!-- Decorative chocolate splash -->
        <div class="absolute -bottom-4 right-16 lg:right-24 animate-float-slow delay-300 opacity-70">
          <img
            src="/images/chocolate_splash.png"
            alt=""
            class="w-24 lg:w-32 drop-shadow-lg"
            aria-hidden="true"
          />
        </div>

        <!-- Circular label on side -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-20 h-20 animate-spin-slow opacity-60">
          <svg viewBox="0 0 80 80" class="w-full h-full">
            <defs>
              <path id="circle-text" d="M 40,40 m -27,0 a 27,27 0 1,1 54,0 a 27,27 0 1,1 -54,0" />
            </defs>
            <text fill="#7B3F1E" font-size="8.5" font-family="Outfit, sans-serif" letter-spacing="1">
              <textPath href="#circle-text">Artesanal · Premium · FEXCO 2026 · </textPath>
            </text>
          </svg>
        </div>

        <!-- Confectionery icons -->
        <div class="absolute top-1/3 left-0 animate-float delay-500">
          <div class="w-10 h-10 rounded-full bg-[#D4A853] flex items-center justify-center shadow-lg">
            <span class="text-lg">🍫</span>
          </div>
        </div>
        <div class="absolute bottom-1/3 right-0 animate-float-reverse delay-700">
          <div class="w-8 h-8 rounded-full bg-[#7B3F1E] flex items-center justify-center shadow-lg">
            <span class="text-sm">✨</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 120L60 110C120 100 240 80 360 75C480 70 600 80 720 85C840 90 960 90 1080 83C1200 77 1320 63 1380 57L1440 50V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#7B3F1E"/>
    </svg>
  </div>
</section>

---
// Footer component
---

<footer class="bg-[#3B1A0A] border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-full bg-[#D4A853] flex items-center justify-center shadow-lg">
            <span class="text-[#3B1A0A] font-bold text-xl" style="font-family: 'Playfair Display', Georgia, serif;">T</span>
          </div>
          <div class="leading-tight">
            <span class="block font-bold text-white text-lg" style="font-family: 'Playfair Display', Georgia, serif;">Taboada</span>
            <span class="block text-xs text-[#D4A853] font-medium tracking-widest uppercase">FEXCO 2026</span>
          </div>
        </div>

        <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-xs">
          Confitería artesanal con más de 15 años de tradición. Cada producto es elaborado 
          con ingredientes seleccionados y el sabor inigualable de nuestra receta familiar.
        </p>

        <!-- Chocolate splash decoration -->
        <div class="flex items-center gap-3 opacity-60">
          <img src="/images/chocolate_splash.png" alt="" class="w-16 h-auto" aria-hidden="true" />
          <div class="flex gap-2">
            {['🍫', '🍪', '✨', '🎁'].map((emoji) => (
              <span class="text-lg">{emoji}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Navigation links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Navegar</h3>
        <ul class="space-y-3">
          {[
            { label: 'Combos Especiales', href: '#combos' },
            { label: 'Productos Premium', href: '#productos' },
            { label: 'Ubicación Stand', href: '#ubicacion' },
            { label: 'Regístrate', href: '#registro' },
            { label: 'Mi Cupón', href: '#cupones' },
          ].map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/60 text-sm hover:text-[#D4A853] transition-colors duration-200 flex items-center gap-2 group"
              >
                <span class="w-0 h-px bg-[#D4A853] group-hover:w-4 transition-all duration-300 inline-block"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#D4A853] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-white/60 text-sm">Stand N° 42, FEXCO 2026<br/>Sector Premium Gastronómico</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#D4A853] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span class="text-white/60 text-sm">+591 7XXXXXXXX<br/>WhatsApp disponible</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[#D4A853] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-white/60 text-sm">Lun–Vie: 9:00–18:00<br/>Finde: 9:00–20:00</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-xs">
        © 2026 Taboada Confitería Artesanal. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-2">
        <span class="text-white/40 text-xs">Hecho con</span>
        <span class="text-[#C0392B]">❤️</span>
        <span class="text-white/40 text-xs">para FEXCO 2026</span>
      </div>
    </div>
  </div>
</footer>

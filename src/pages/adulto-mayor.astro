---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Programa Legado · Adulto Mayor | Chocolates Taboada">

<style is:global>
  :root {
    --oro-viejo: #C4A77D;
    --beige-seda: #FDF5E6;
    --cafe-profundo: #1A0D0A;
    --font-serif: "Playfair Display", serif;
  }

  body { background-color: var(--beige-seda); margin: 0; }

  /* ── BARRA SUPERIOR BOUTIQUE ── */
  .am-topbar {
    background: var(--cafe-profundo);
    padding: 15px 5%;
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid rgba(196, 167, 125, 0.2);
  }
  .back-link {
    color: var(--oro-viejo); text-decoration: none; font-size: 12px;
    font-weight: 700; letter-spacing: 0.1em; display: flex; align-items: center; gap: 8px;
  }
  .topbar-logo { height: 35px; filter: brightness(0) invert(1); }

  /* ── HERO LEGADO ── */
  .am-hero {
    background-color: var(--cafe-profundo);
    padding: 100px 24px 60px;
    position: relative; text-align: center; overflow: hidden;
  }
  .am-hero::after {
    content: ''; position: absolute; inset: 0;
    background-image: url('/images/port2.jpg');
    background-size: cover; background-position: center; opacity: 0.1;
  }
  .am-hero-inner { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }

  .hero-tag {
    color: var(--oro-viejo); font-size: 10px; font-weight: 800;
    letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 20px; display: block;
  }
  .hero-title {
    font-family: var(--font-serif); font-size: clamp(2rem, 6vw, 3.5rem);
    color: var(--beige-seda); line-height: 1.1; margin-bottom: 20px;
  }
  .hero-title span { color: var(--oro-viejo); font-style: italic; }

  /* ── VISTA PREVIA CREDENCIAL (DISEÑO BOUTIQUE) ── */
  .preview-section { max-width: 500px; margin: -50px auto 40px; padding: 0 24px; position: relative; z-index: 10; }
  .luxury-credential {
    background: var(--cafe-profundo);
    border: 1px solid var(--oro-viejo);
    border-radius: 24px; padding: 30px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.4);
    position: relative; overflow: hidden;
  }
  .luxury-credential::before {
    content: 'T'; position: absolute; right: -20px; bottom: -20px;
    font-family: var(--font-serif); font-size: 150px; color: rgba(196, 167, 125, 0.05);
  }

  .cred-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
  .cred-label { color: var(--oro-viejo); font-size: 9px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; }
  .cred-name { font-family: var(--font-serif); font-size: 22px; color: var(--beige-seda); margin: 5px 0; }
  .cred-ci { color: var(--oro-viejo); font-size: 12px; opacity: 0.8; }
  .cred-pct { text-align: right; }
  .cred-number { font-family: var(--font-serif); font-size: 2.5rem; color: var(--oro-viejo); line-height: 1; }

  /* ── FORMULARIO LIMPIO ── */
  .form-container { max-width: 600px; margin: 40px auto 100px; padding: 0 24px; }
  .field-group { margin-bottom: 20px; }
  .field-group label { 
    display: block; font-size: 10px; font-weight: 800; color: var(--cafe-profundo); 
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;
  }
  .field-group input {
    width: 100%; padding: 15px; border: 1px solid #D7CCC8; border-radius: 12px;
    background: white; font-family: inherit; font-size: 15px; color: var(--cafe-profundo);
    transition: 0.3s; box-sizing: border-box;
  }
  .field-group input:focus { outline: none; border-color: var(--oro-viejo); box-shadow: 0 0 0 4px rgba(196, 167, 125, 0.1); }

  .btn-submit {
    width: 100%; padding: 20px; background: var(--cafe-profundo); color: var(--oro-viejo);
    border: 1px solid var(--oro-viejo); border-radius: 15px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.2em; cursor: pointer; transition: 0.3s;
    margin-top: 20px;
  }
  .btn-submit:hover { background: var(--oro-viejo); color: var(--cafe-profundo); }

</style>

<div class="am-page">
  <header class="am-topbar">
    <a href="/beneficios" class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      VOLVER
    </a>
    <img src="/images/logo-taboada.png" class="topbar-logo" alt="Taboada" />
  </header>

  <section class="am-hero">
    <div class="am-hero-inner">
      <span class="hero-tag">Programa Legado</span>
      <h1 class="hero-title">Credencial de Honor para <span>Adultos Mayores</span></h1>
      <p style="color: var(--beige-seda); opacity: 0.7; font-size: 16px; line-height: 1.6;">
        Otorgamos un descuento vitalicio del 5% en nuestra sucursal de La Recoleta. <br/>
        Regístralo ahora y genera su credencial digital al instante.
      </p>
    </div>
  </section>

  <div class="preview-section">
    <div class="luxury-credential">
      <div class="cred-header">
        <div>
          <span class="cred-label">Miembro Legado</span>
          <div class="cred-name" id="prev-name">Nombre Familiar</div>
          <div class="cred-ci" id="prev-ci">CI: ——————</div>
        </div>
        <div class="cred-pct">
          <div class="cred-number">5%</div>
          <span class="cred-label">DESC.</span>
        </div>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: flex-end; border-top: 1px solid rgba(196, 167, 125, 0.2); padding-top: 15px;">
        <span class="cred-label" style="font-size: 7px;">VÁLIDO EN: LA RECOLETA</span>
        <span id="prev-id" style="font-family: monospace; font-size: 10px; color: var(--oro-viejo); opacity: 0.6;">#TAB-000000</span>
      </div>
    </div>
  </div>

  <main class="form-container">
    <form id="am-form">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
        <div class="field-group">
          <label>Nombre</label>
          <input type="text" id="am-nombre" placeholder="Ej. Juan" required />
        </div>
        <div class="field-group">
          <label>Apellidos</label>
          <input type="text" id="am-apellido" placeholder="Ej. Pérez" required />
        </div>
      </div>
      
      <div class="field-group">
        <label>Carnet de Identidad</label>
        <input type="text" id="am-ci" placeholder="Ej. 1234567 CB" required />
      </div>

      <div class="field-group">
        <label>Número de WhatsApp (Notificación)</label>
        <input type="tel" id="am-tel" placeholder="70000000" required />
      </div>

      <button type="submit" class="btn-submit" id="submit-btn">Generar Credencial 🎖️</button>
    </form>
  </main>

  <footer style="background: var(--cafe-profundo); padding: 40px; text-align: center; color: var(--oro-viejo); font-size: 10px; letter-spacing: 0.2em;">
    © 2026 CHOCOLATES TABOADA · TRADICIÓN DE FAMILIA
  </footer>
</div>

<script is:inline>
  // ID Único
  const randomID = "TAB-" + Math.floor(100000 + Math.random() * 900000);
  document.getElementById('prev-id').textContent = "#" + randomID;

  // Actualización en tiempo real
  const inputNom = document.getElementById('am-nombre');
  const inputApe = document.getElementById('am-apellido');
  const inputCI = document.getElementById('am-ci');

  function update() {
    const full = (inputNom.value + " " + inputApe.value).trim();
    document.getElementById('prev-name').textContent = full || "Nombre Familiar";
    document.getElementById('prev-ci').textContent = "CI: " + (inputCI.value || "——————");
  }

  inputNom.addEventListener('input', update);
  inputApe.addEventListener('input', update);
  inputCI.addEventListener('input', update);

  // Manejo del envío
  document.getElementById('am-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    btn.textContent = "REGISTRANDO...";
    btn.style.opacity = "0.7";
    
    await new Promise(r => setTimeout(r, 1500));
    alert("¡Felicidades! La credencial ha sido generada. Recibirás la confirmación por WhatsApp.");
    window.location.href = "/beneficios";
  });
</script>
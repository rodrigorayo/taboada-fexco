---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Programa Legado · Adulto Mayor | Chocolates Taboada">

<style is:global>
  :root {
    --oro-viejo: #C4A77D;
    --beige-seda: #FDF5E6;
    --cafe-profundo: #1A0D0A;
    --font-serif: "Playfair Display", serif;
  }

  body { background-color: var(--beige-seda); margin: 0; }

  /* ── BARRA SUPERIOR BOUTIQUE ── */
  .am-topbar {
    background: var(--cafe-profundo);
    padding: 15px 5%;
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid rgba(196, 167, 125, 0.2);
  }
  .back-link {
    color: var(--oro-viejo); text-decoration: none; font-size: 12px;
    font-weight: 700; letter-spacing: 0.1em; display: flex; align-items: center; gap: 8px;
  }
  .topbar-logo { height: 35px; filter: brightness(0) invert(1); }

  /* ── HERO LEGADO ── */
  .am-hero {
    background-color: var(--cafe-profundo);
    padding: 100px 24px 60px;
    position: relative; text-align: center; overflow: hidden;
  }
  .am-hero::after {
    content: ''; position: absolute; inset: 0;
    background-image: url('/images/port2.jpg');
    background-size: cover; background-position: center; opacity: 0.1;
  }
  .am-hero-inner { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }

  .hero-tag {
    color: var(--oro-viejo); font-size: 10px; font-weight: 800;
    letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 20px; display: block;
  }
  .hero-title {
    font-family: var(--font-serif); font-size: clamp(2rem, 6vw, 3.5rem);
    color: var(--beige-seda); line-height: 1.1; margin-bottom: 20px;
  }
  .hero-title span { color: var(--oro-viejo); font-style: italic; }

  /* ── FORMULARIO LIMPIO (PASO 1) ── */
  .form-container { max-width: 600px; margin: -40px auto 100px; padding: 0 24px; position: relative; z-index: 10; }
  
  .card-blanca {
    background: white;
    padding: 40px 30px;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .field-group { margin-bottom: 20px; text-align: left; }
  .field-group label { 
    display: block; font-size: 10px; font-weight: 800; color: var(--cafe-profundo); 
    text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;
  }
  .field-group input {
    width: 100%; padding: 15px; border: 1px solid #D7CCC8; border-radius: 12px;
    background: #fafafa; font-family: inherit; font-size: 15px; color: var(--cafe-profundo);
    transition: 0.3s; box-sizing: border-box;
  }
  .field-group input:focus { outline: none; border-color: var(--oro-viejo); box-shadow: 0 0 0 4px rgba(196, 167, 125, 0.1); background: white; }

  .btn-submit {
    width: 100%; padding: 20px; background: var(--cafe-profundo); color: var(--oro-viejo);
    border: 1px solid var(--oro-viejo); border-radius: 15px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.2em; cursor: pointer; transition: 0.3s;
    margin-top: 20px;
  }
  .btn-submit:hover { background: var(--oro-viejo); color: var(--cafe-profundo); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(196, 167, 125, 0.2); }

  /* ==========================================
     ¡AQUÍ ESTÁ EL REDISEÑO ESTILO TARJETA! (PASO 2)
     ========================================== */
  .success-container {
    max-width: 500px; margin: -40px auto 100px; padding: 0 24px; position: relative; z-index: 10;
    display: none; /* Oculto al inicio */
    text-align: center;
    animation: fadeInSlideUp 0.6s ease-out forwards;
  }

  @keyframes fadeInSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .success-msg { color: var(--cafe-profundo); font-family: var(--font-serif); font-size: 1.8rem; margin-bottom: 5px; }
  .success-sub { color: #5D4037; font-size: 13px; margin-bottom: 30px; }

  /* ── ESTILOS DEL PLÁSTICO DE LA TARJETA ── */
  .luxury-credential {
    /* Relación de aspecto de tarjeta bancaria */
    width: 100%; max-width: 480px; aspect-ratio: 1.6 / 1; margin: 0 auto;
    
    /* Fondo Premium: Degradado radial café profundo */
    background: radial-gradient(circle at center, #2c1611 0%, #1A0D0A 70%), var(--cafe-profundo);
    border: 1px solid rgba(196, 167, 125, 0.3);
    border-radius: 18px; padding: 30px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    
    position: relative; overflow: hidden;
    text-align: left;
    display: flex; flex-direction: column; justify-content: space-between;
    box-sizing: border-box;
  }

  /* ── Brillo de material plástico superficial ── */
  .luxury-credential::before {
    content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
    background: linear-gradient(135deg, rgba(255,255,255,0) 40%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0) 60%);
    z-index: 1; pointer-events: none;
  }

  /* ── Patrón micro-geométrico de fondo (sutil) ── */
  .luxury-credential::after {
    content: 'T'; position: absolute; right: -20px; bottom: -20px;
    font-family: var(--font-serif); font-size: 180px; color: rgba(196, 167, 125, 0.04); z-index: 0;
  }

  /* ── Ícono del Chip Dorado EMV ── */
  .card-chip {
    width: 45px; height: 35px;
    background: linear-gradient(135deg, #d3c7b2 0%, #b8a688 100%);
    border-radius: 6px; position: relative; margin-bottom: 15px; z-index: 2;
  }
  .card-chip::after {
    content: ''; position: absolute; inset: 5px;
    border: 1px solid rgba(26, 13, 10, 0.2); border-radius: 3px;
    background-image: linear-gradient(0deg, transparent 45%, rgba(26, 13, 10, 0.2) 50%, transparent 55%), linear-gradient(90deg, transparent 45%, rgba(26, 13, 10, 0.2) 50%, transparent 55%);
  }

  /* ── Tipografía Estilo "Embose" (Relieve Troquelado) ── */
  .embossed-text {
    font-family: 'OCR-A Extended', monospace, serif; /* Fuente estilo tarjeta bancaria */
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--oro-viejo);
    text-shadow: 1px 1px 0px rgba(255,255,255,0.1), -1px -1px 0px rgba(0,0,0,0.3);
  }

  .cred-header { display: flex; justify-content: space-between; align-items: flex-start; position: relative; z-index: 2; }
  .cred-label { color: rgba(196, 167, 125, 0.8); font-size: 9px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; }
  
  /* El nombre del cliente en relieve */
  .cred-name { 
    font-family: var(--font-serif); font-size: 24px; margin: 2px 0 0; line-height: 1.1;
    color: var(--beige-seda);
    text-shadow: 1px 1px 0px rgba(255,255,255,0.1), -1px -1px 0px rgba(0,0,0,0.3);
  }
  
  .cred-pct { text-align: right; }
  .cred-number { font-family: var(--font-serif); font-size: 3rem; color: var(--oro-viejo); line-height: 1; margin-bottom: 5px; }

  /* ── Contenedor para el ID y la Validez ── */
  .card-footer {
    display: flex; justify-content: space-between; align-items: flex-end;
    border-top: 1px solid rgba(196, 167, 125, 0.15); padding-top: 15px;
    position: relative; z-index: 2;
  }
  
  /* El número de tarjeta en relieve */
  #final-id { font-size: 14px; opacity: 0.9; }

  .btn-volver-success {
    display: inline-block; padding: 15px 30px; background: transparent; color: var(--cafe-profundo);
    border: 2px solid var(--cafe-profundo); border-radius: 50px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: 0.3s;
    margin-top: 40px; text-decoration: none; font-size: 11px;
  }
  .btn-volver-success:hover { background: var(--cafe-profundo); color: var(--beige-seda); }

</style>

<div class="am-page">
  <header class="am-topbar">
    <a href="/beneficios" class="back-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      VOLVER
    </a>
    <img src="/images/logo-taboada.png" class="topbar-logo" alt="Taboada" />
  </header>

  <section class="am-hero">
    <div class="am-hero-inner">
      <span class="hero-tag">Programa Legado</span>
      <h1 class="hero-title">Credencial de Honor para <span>Adultos Mayores</span></h1>
      <p style="color: var(--beige-seda); opacity: 0.7; font-size: 16px; line-height: 1.6;">
        Otorgamos un descuento vitalicio del 5% en nuestra sucursal de La Recoleta. <br/>
        Regístralo ahora y genera su credencial digital al instante.
      </p>
    </div>
  </section>

  <main class="form-container" id="paso-formulario">
    <div class="card-blanca">
      <form id="am-form">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
          <div class="field-group">
            <label>Nombre</label>
            <input type="text" id="am-nombre" placeholder="Ej. Juan" required />
          </div>
          <div class="field-group">
            <label>Apellidos</label>
            <input type="text" id="am-apellido" placeholder="Ej. Pérez" required />
          </div>
        </div>
        
        <div class="field-group">
          <label>Fecha de nacimiento</label>
          <input type="date" id="am-fecha" required />
        </div>

        <div class="field-group">
          <label>Número de WhatsApp (Notificación)</label>
          <input type="tel" id="am-tel" placeholder="Ej. 70000000" required />
        </div>

        <button type="submit" class="btn-submit" id="submit-btn">Generar Credencial 🎖️</button>
      </form>
    </div>
  </main>

  <div class="success-container" id="paso-credencial">
    <h2 class="success-msg">¡Cliente Registrado!</h2>
    <p class="success-sub">La tarjeta ha sido vinculada al sistema exitosamente.</p>

    <div class="luxury-credential">
      
      <div class="cred-header">
        <img src="/images/taboada-logo.png" style="height: 25px; filter: brightness(0) invert(1);" alt="Taboada" />
        <span class="cred-label">Miembro Legado</span>
      </div>
      
      <div>
        <div class="card-chip"></div>
        <div class="cred-name" id="final-name">Nombre Apellido</div>
      </div>
      
      <div class="card-footer">
        <div>
          <span class="cred-label" style="font-size: 7px;">ID ÚNICO</span>
          <div id="final-id" class="embossed-text">#TAB-000000</div>
        </div>
        <div class="cred-pct" style="display: flex; align-items: center; gap: 8px;">
           <div class="cred-number" style="font-size: 2.2rem; margin:0;">5%</div>
           <span class="cred-label" style="margin:0;">DESC. <br> VITALICIO</span>
        </div>
      </div>
    </div>

    <a href="/beneficios" class="btn-volver-success">← Volver a Mis Beneficios</a>
  </div>

  <footer style="background: var(--cafe-profundo); padding: 40px; text-align: center; color: var(--oro-viejo); font-size: 10px; letter-spacing: 0.2em;">
    © 2026 CHOCOLATES TABOADA · TRADICIÓN DE FAMILIA
  </footer>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('am-form');
    const pasoFormulario = document.getElementById('paso-formulario');
    const pasoCredencial = document.getElementById('paso-credencial');
    
    // Generar un ID único aleatorio (se mantiene la lógica)
    const randomID = "TAB-" + Math.floor(100000 + Math.random() * 900000);
    document.getElementById('final-id').textContent = "#" + randomID;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const btn = document.getElementById('submit-btn');
      
      btn.textContent = "CREANDO CLIENTE...";
      btn.style.opacity = "0.7";
      btn.style.pointerEvents = "none";
      
      await new Promise(r => setTimeout(r, 1500));
      
      const nombreInput = document.getElementById('am-nombre').value.trim();
      const apellidoInput = document.getElementById('am-apellido').value.trim();
      
      // Inyectamos el nombre en la tarjeta digital
      document.getElementById('final-name').textContent = `${nombreInput} ${apellidoInput}`;
      
      // Ocultamos el formulario y mostramos la tarjeta
      pasoFormulario.style.display = 'none';
      pasoCredencial.style.display = 'block';

      pasoCredencial.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });
</script>
</AppLayout>
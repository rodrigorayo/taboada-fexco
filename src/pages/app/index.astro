---
import AppLayout from '../layouts/AppLayout.astro';

// 1. Datos de los combos
const combos = [
  { id:'c1', name:'Combo Familiar',     desc:'2 bolsas de trufas belgas + galletas + panes artesanales', price:'75', img:'/images/port1.png' },
  { id:'c2', name:'Combo Goloso',       desc:'Trufas premium + galletas gourmet + pastelito artesanal', price:'45', img:'/images/port1.png' },
  { id:'c3', name:'Combo Regalo FEXCO', desc:'Exclusivo surtido en elegante caja (Edición Limitada)', price:'95', img:'/images/combo_regalo.png' },
];

// 2. Datos de sucursales
const sucursales = [
  { ciudad: 'Cochabamba', locales: [
    { nombre: 'Boutique La Recoleta', dir: 'Av. Potosí, Zona La Recoleta' },
    { nombre: 'Punto Heroínas', dir: 'Calle Heroínas, Centro Histórico' }
  ]},
  { ciudad: 'La Paz', locales: [
    { nombre: 'Boutique Calacoto', dir: 'Zona Calacoto, Calle 15' }
  ]}
];
---

<AppLayout title="Chocolates Taboada · FEXCO 2026">

<style is:global>
  :root {
    --oro-viejo: #C4A77D;
    --beige-seda: #FDF5E6;
    --cafe-profundo: #1A0D0A;
    --font-serif: "Playfair Display", serif; 
  }

  /* ── Barra de Logos Fija con Fondo Café Permanente ── */
  .fixed-header {
    position: fixed;
    top: 0; left: 0; width: 100%;
    padding: 10px 5%; /* Un poco más compacto para que no ocupe mucho espacio fijo */
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    /* Fondo café profundo permanente con un borde inferior sutil en oro */
    background-color: var(--cafe-profundo);
    border-bottom: 1px solid rgba(196, 167, 125, 0.3);
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    pointer-events: auto; /* Permitimos clics en la barra si hay enlaces */
  }
  .fixed-header img { pointer-events: auto; }
  .logo-main { height: clamp(30px, 4vw, 45px); filter: brightness(0) invert(1); } /* Un poco más pequeños para la barra fija */
  .logo-fexco { height: clamp(18px, 3vw, 25px); opacity: 0.9; }

  /* ── SECCIÓN 1: HERO & REGISTRO (TOP) ── */
  .hero-landing {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--cafe-profundo);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background: 
      linear-gradient(135deg, rgba(26, 13, 10, 0.95) 0%, rgba(26, 13, 10, 0.8) 50%, rgba(26, 13, 10, 0.6) 100%),
      url('/images/port2.jpg') center/cover no-repeat;
    z-index: 0;
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    padding: 100px 24px 0; /* Espacio superior aumentado para compensar la barra fija */
    display: grid; grid-template-columns: 1fr;
    gap: 30px; width: 100%;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner { grid-template-columns: 1.1fr 0.9fr; gap: 60px; padding: 120px 40px 0; }
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 7vw, 4rem);
    color: var(--beige-seda); line-height: 1.1; margin-bottom: 15px;
  }
  .hero-title span { font-style: italic; font-weight: 400; color: #E0C9A6; }

  .hero-desc {
    color: rgba(253, 245, 230, 0.85); max-width: 480px; 
    font-size: clamp(14px, 3vw, 17px); line-height: 1.5;
  }

  .form-card {
    background: rgba(26, 13, 10, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(196, 167, 125, 0.3);
    border-radius: 20px;
    padding: 25px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .form-card h2 { color: var(--oro-viejo); font-family: var(--font-serif); font-size: 1.5rem; text-align: center; margin-bottom: 5px; }
  .form-card p { color: #D7CCC8; font-size: 13px; text-align: center; margin-bottom: 20px; }

  .glass-field { margin-bottom: 12px; }
  .glass-field label { color: var(--oro-viejo); font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; display: block; }
  .glass-field input {
    background: rgba(255, 255, 255, 0.08) !important; border: 1px solid rgba(196, 167, 125, 0.2) !important;
    padding: 12px !important; color: #fff !important; border-radius: 8px !important; width: 100%; font-size: 14px;
  }

  .btn-register {
    width: 100%; padding: 15px; background: linear-gradient(135deg, var(--oro-viejo), #A68A64);
    color: #1A0D0A; font-weight: 900; border: none; border-radius: 10px; cursor: pointer; text-transform: uppercase;
    margin-top: 10px;
  }

  /* ── SECCIÓN 2: COMBOS (DESPUÉS DEL HERO) ── */
  .gallery-section { padding: 100px 24px; background: var(--beige-seda); text-align: center; }
  .gallery-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px; max-width: 1200px; margin: 40px auto 0;
  }
  .lux-card { background: white; padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); text-align: center; }
  .lux-card img { max-height: 180px; width: auto; margin-bottom: 20px; }
  .lux-card h3 { font-family: var(--font-serif); color: var(--cafe-profundo); font-size: 1.5rem; margin-bottom: 10px; }
  .lux-card p { color: #5D4037; font-size: 0.9rem; line-height: 1.4; margin-bottom: 15px; }
  .lux-price { color: var(--oro-viejo); font-weight: 800; font-size: 1.4rem; }

  /* ── SECCIÓN 3: DIRECCIONES (FOOTER) ── */
  .footer-info {
    background: var(--cafe-profundo);
    padding: 80px 24px;
    color: var(--beige-seda);
    text-align: center;
    border-top: 1px solid rgba(196, 167, 125, 0.2);
  }
  .footer-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px; max-width: 1000px; margin: 0 auto 50px;
  }
  .footer-city { color: var(--oro-viejo); text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700; margin-bottom: 20px; font-size: 0.9rem; }
  .footer-local { margin-bottom: 15px; }
  .footer-local strong { display: block; font-family: var(--font-serif); font-size: 1.1rem; margin-bottom: 5px; }
  .footer-local span { opacity: 0.7; font-size: 0.9rem; }

  .social-links { display: flex; justify-content: center; gap: 20px; }
  .social-links a { color: var(--oro-viejo); text-decoration: none; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; }
</style>

<div id="page-root">
  <div class="fixed-header luxury-wrapper">
    <img src="/images/logo-taboada.png" alt="Taboada" class="logo-main" />
    <img src="/images/fexco-logo-secondary.png" alt="FEXCO" class="logo-fexco" />
  </div>

  <section class="hero-landing">
    <div class="hero-bg"></div>
    <div class="hero-inner">
      <div class="hero-content">
        <span style="color: var(--oro-viejo); font-weight: 700; letter-spacing: 0.2em; font-size: 11px; text-transform: uppercase;">Orgullo Boliviano en FEXCO</span>
        <h1 class="hero-title">El Sabor de<br/><span>Nuestra Historia</span></h1>
        <p class="hero-desc">
          Somos la primera fábrica de chocolates de Bolivia. Llevamos generaciones perfeccionando una receta familiar para ofrecerte el chocolate más exquisito.
        </p>
      </div>

      <div class="form-card">
        <h2>Únete a la Familia</h2>
        <p>Regístrate ahora y recibe regalos pensados para ti.</p>
        
        <form id="form-registro">
          <div class="glass-field">
            <label>Nombre Completo</label>
            <input type="text" id="reg-nombre" placeholder="Tu nombre" required />
          </div>
          <div class="glass-field">
            <label>Correo Electrónico</label>
            <input type="email" id="reg-correo" placeholder="ejemplo@gmail.com" required />
          </div>
          <div class="glass-field">
            <label>Número de WhatsApp</label>
            <input type="tel" id="reg-wpp" placeholder="70000000" required />
          </div>
          <button type="submit" class="btn-register">Registrarme ✦</button>
        </form>
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <h2 style="font-family: var(--font-serif); font-size: 2.5rem; color: var(--cafe-profundo); margin-bottom: 10px;">Colección FEXCO 2026</h2>
    <p style="color: #5D4037; margin-bottom: 40px;">Ediciones limitadas disponibles solo en nuestro stand.</p>
    
    <div class="gallery-grid">
      {combos.map(c => (
        <div class="lux-card">
          <img src={c.img} alt={c.name} />
          <h3>{c.name}</h3>
          <p>{c.desc}</p>
          <div class="lux-price">Bs. {c.price}</div>
        </div>
      ))}
    </div>
  </section>

  <footer class="footer-info">
    <h2 style="font-family: var(--font-serif); font-size: 2rem; margin-bottom: 50px;">Nuestras Boutiques</h2>
    <div class="footer-grid">
      {sucursales.map(s => (
        <div>
          <div class="footer-city">{s.ciudad}</div>
          {s.locales.map(l => (
            <div class="footer-local">
              <strong>{l.nombre}</strong>
              <span>{l.dir}</span>
            </div>
          ))}
        </div>
      ))}
    </div>

    <div class="social-links">
      <a href="#">FACEBOOK</a>
      <a href="#">INSTAGRAM</a>
      <a href="#">TIKTOK</a>
      <a href="#">WHATSAPP</a>
    </div>
    
    <p style="margin-top: 60px; font-size: 10px; opacity: 0.4; letter-spacing: 0.1em;">© 2026 CHOCOLATES TABOADA · DESDE 1903</p>
  </footer>
</div>

<script>
  const form = document.getElementById('form-registro');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const n = (document.getElementById('reg-nombre') as HTMLInputElement).value;
    const c = (document.getElementById('reg-correo') as HTMLInputElement).value;
    // Guardamos los datos
    sessionStorage.setItem('taboada_user', JSON.stringify({ nombre: n, correo: c }));
    window.location.href = '/comunidad.astro';
  });
</script>
const sucursales = [
  { ciudad:'Cochabamba', locales:[
    { nombre:'Boutique La Recoleta',  dir:'Av. Potosí, Zona La Recoleta' },
    { nombre:'Punto Heroínas',     dir:'Calle Heroínas, Centro Histórico' },
  ]},
  { ciudad:'La Paz', locales:[
    { nombre:'Boutique Calacoto',     dir:'Zona Calacoto, La Paz' },
  ]}
];
---
<AppLayout title="Boutique Taboada · Colección FEXCO 2026">

<style is:global>
  /* ──── BASE PREMIUM ──── */
  body {
    background-color: #F8F5F1; 
    background-image: radial-gradient(circle at top right, rgba(212,168,83,0.05), transparent 600px);
    overflow-x: hidden;
  }
  
  /* CONTENEDOR AMPLIO */
  .luxury-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }
  @media (min-width: 768px) {
    .luxury-wrapper { padding: 0 40px; }
  }

  /* Text Tools */
  .serif { font-family: var(--font-serif); }
  .gold-text { color: var(--gold); }
  .choco-text { color: var(--choco); }

  /* ──── HEADER ──── */
  .premium-header {
    padding: 30px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  @media (min-width: 768px) { .premium-header { padding: 40px 0; } }

  .header-logo {
    display: flex; align-items: center; gap: 15px;
    text-decoration: none; color: var(--choco);
  }
  .header-logo img { height: 50px; width: auto; mix-blend-mode: multiply; }
  @media (min-width: 768px) { .header-logo img { height: 60px; } }
  
  .logo-divider { width: 1px; height: 30px; background: #EAD9C5; }

  /* ──── HERO BOUTIQUE (AHORA CON REGISTRO) ──── */
  .hero-luxury {
    padding: 60px 0 100px;
    position: relative;
  }
  .hero-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 60px;
  }
  @media (min-width: 1024px) {
    .hero-grid { flex-direction: row; text-align: left; align-items: flex-start; gap: 80px; padding: 40px 0 100px; }
  }
  
  .hero-title {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    line-height: 1.05;
    color: var(--choco);
    margin-bottom: 24px;
  }
  .hero-title span { font-style: italic; font-weight: 400; color: var(--choco-mid); }
  
  .hero-desc {
    font-size: 18px;
    color: #6A4433;
    line-height: 1.8;
    max-width: 550px;
    font-weight: 400;
  }
  @media (max-width: 1023px) { .hero-desc { margin: 0 auto; } }

  .hero-visual {
    position: relative;
    width: 100%;
    max-width: 450px;
    height: 450px;
    margin: 0 auto;
    position: sticky;
    top: 100px;
  }
  @media (min-width: 1024px) {
    .hero-visual { max-width: 600px; height: 600px; }
  }
  
  .hero-visual::before {
    content: ''; position: absolute; inset: 10px;
    border-radius: 50%; border: 1px dashed rgba(212,168,83,0.4);
    animation: rotate 60s linear infinite;
  }
  @media (min-width: 1024px) { .hero-visual::before { inset: 40px; } }
  @keyframes rotate { 100% { transform: rotate(360deg); } }
  
  .hero-product-main {
    position: absolute; top: 10%; left: 0; right: 0; margin: auto;
    width: 300px; filter: drop-shadow(0 30px 40px rgba(59,26,10,0.15));
    z-index: 2;
  }
  @media (min-width: 1024px) { .hero-product-main { width: 420px; } }

  /* ──── FORMULARIO DIRECTO EN HERO (BLANCO/CLARO) ──── */
  .hero-form-box {
    background: #FFFFFF;
    border: 1px solid #EAD9C5;
    border-radius: 24px;
    padding: 35px 30px;
    box-shadow: 0 20px 40px rgba(59, 26, 10, 0.04);
    max-width: 550px;
    margin-top: 40px;
    text-align: left;
  }
  @media (max-width: 1023px) { .hero-form-box { margin: 40px auto 0; } }

  .lux-field-light { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; width: 100%; }
  .lux-field-light label { font-size: 12px; letter-spacing: 0.1em; color: #8F6D59; text-transform: uppercase; font-weight: 700; }
  .lux-field-light input {
    background: transparent !important;
    border: none !important; border-bottom: 2px solid #EAD9C5 !important;
    border-radius: 0 !important; color: var(--choco) !important; padding: 12px 0 !important; font-size: 18px !important;
    transition: border-color 0.3s !important; box-shadow: none !important; width: 100%;
  }
  .lux-field-light input:focus { border-bottom-color: var(--gold) !important; box-shadow: none !important; outline: none; }

  .btn-hero {
    width: 100%; padding: 20px; border-radius: 12px; background: var(--choco); color: var(--white);
    font-family: var(--font); font-weight: 800; font-size: 15px; letter-spacing: 0.15em; text-transform: uppercase;
    border: none; cursor: pointer; transition: background 0.3s, transform 0.3s; margin-top: 10px;
    box-shadow: 0 10px 20px rgba(59,26,10,0.1);
  }
  .btn-hero:hover { background: var(--gold); transform: translateY(-2px); }
  
  /* ──── REWARDS (AUTH STATE) ──── */
  #state-unregistered { display: block; }
  #state-registered { display: none; }
  .is-auth #state-unregistered { display: none; }
  .is-auth #state-registered { display: block; animation: fadeIn 0.5s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* ──── COMBOS (BOUTIQUE GALLERY) ──── */
  .gallery-section { padding: 100px 0 140px; text-align: center; }
  @media (min-width: 1024px) { .gallery-section { padding: 80px 0 140px; } }
  
  .gallery-grid {
    display: grid; grid-template-columns: 1fr; gap: 50px; margin-top: 60px;
  }
  @media (min-width: 768px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 40px; } }
  @media (min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 60px; margin-top: 80px; } }

  .lux-card {
    background: transparent; border: none; text-align: center; position: relative;
    padding: 20px; transition: transform 0.4s;
  }
  .lux-card:hover { transform: translateY(-15px); }
  
  .lc-img-box {
    background: #F0E8DD; border-radius: 250px 250px 15px 15px; height: 350px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 30px; position: relative;
    box-shadow: inset 0 -20px 40px rgba(59,26,10,0.03), 0 20px 40px rgba(59,26,10,0.06);
  }
  @media (min-width: 900px) { .lc-img-box { height: 420px; margin-bottom: 40px; } }
  
  .lc-img-box img { max-height: 240px; filter: drop-shadow(0 25px 35px rgba(59,26,10,0.2)); transition: transform 0.5s; }
  @media (min-width: 900px) { .lc-img-box img { max-height: 280px; } }
  .lux-card:hover .lc-img-box img { transform: scale(1.08); }

  .lc-badge {
    position: absolute; top: 20px; left: 50%; transform: translateX(-50%);
    font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--choco); border-bottom: 2px solid var(--choco); padding-bottom: 6px;
    white-space: nowrap;
  }

  .lc-title { font-size: 26px; color: var(--choco); margin-bottom: 16px; }
  @media (min-width: 900px) { .lc-title { font-size: 30px; } }
  
  .lc-desc { font-size: 15px; color: #8F6D59; line-height: 1.7; margin-bottom: 24px; padding: 0 15px; }
  .lc-price-box { font-family: var(--font-serif); color: var(--choco); margin-bottom: 30px; }
  .lc-price { font-size: 32px; font-weight: 800; font-style: italic; }
  @media (min-width: 900px) { .lc-price { font-size: 38px; } }
  .lc-old { font-size: 16px; color: #B39A86; text-decoration: line-through; margin-right: 16px; }
  
  .btn-outline-lux {
    display: inline-block; border: 2px solid var(--choco); border-radius: 50px;
    padding: 16px 40px; font-size: 12px; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--choco); background: transparent; cursor: pointer; transition: all 0.3s;
  }
  @media (min-width: 900px) { .btn-outline-lux { font-size: 13px; padding: 18px 45px; } }
  .btn-outline-lux:hover { background: var(--choco); color: var(--white); }

  /* ──── SUCURSALES ──── */
  .stores-section {
    border-top: 1px solid #EAD9C5;
    padding: 80px 0;
    text-align: center;
  }
  @media (min-width: 1024px) { .stores-section { padding: 120px 0; } }
  
  .store-grid {
    display: flex; flex-direction: column; gap: 60px; margin-top: 60px;
    max-width: 1000px; margin-inline: auto;
  }
  @media (min-width: 768px) { .store-grid { flex-direction: row; justify-content: center; gap: 100px; } }
  
  .st-col { text-align: center; }
  .st-city { font-size: 14px; font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 30px; }
  .st-name { font-family: var(--font-serif); font-size: 22px; font-weight: 700; color: var(--choco); margin-bottom: 8px; }
  .st-dir { font-size: 16px; color: #8F6D59; margin-bottom: 30px; }
</style>

<div id="page-root">
<header class="luxury-wrapper premium-header" style="padding-top: 15px; padding-bottom: 15px; position: relative; z-index: 10;">
  <a href="/" class="header-logo">
    <img src="/images/logo-taboada.png" alt="Taboada" style="width: 100%; max-width: 200px; height: auto; mix-blend-mode: multiply;" />
  </a>
  <div>
    <img src="/images/fexco-logo-secondary.png" alt="FEXCO" style="height: 28px;" />
  </div>
</header>

<div style="position: relative; width: 100vw; margin-left: calc(50% - 50vw); overflow: hidden; background-color: #F8F5F1;">
  
  <img src="/images/port2.jpg" alt="Cacao" style="position: absolute; top: 0; right: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; z-index: 0;" />
  
  <style>
    /* 1. EL DEGRADADO SEMITRANSPARENTE */
    .gradiente-crema {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;
      /* En Celular: Semitransparente en toda la pantalla para que el cacao se luzca de fondo */
      background: linear-gradient(to bottom, rgba(248,245,241,0.85) 0%, rgba(248,245,241,0.5) 80%, transparent 100%);
    }
    
    /* 2. CENTRADO EN CELULAR, A LA IZQUIERDA EN PC */
    .responsive-hero-content {
      display: flex; flex-direction: column; align-items: center; text-align: center;
      padding: 0 10px; /* Margen extra a los lados en celular */
    }
    

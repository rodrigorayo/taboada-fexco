<div class="toast" id="toast" style="background:var(--choco); color:var(--white); border:1px solid rgba(212,168,83,0.5); padding: 16px 24px; font-size: 16px; font-weight: 600;"><span id="toast-msg"></span></div>

</AppLayout>

<script>
  const root = document.getElementById('page-root')!;

  // -- AUTH FLOW --
  function applyAuth(nombre: string) {
    root.classList.add('is-auth');
    const ini = document.getElementById('user-initial');
    const grt = document.getElementById('user-greeting');
    
    const primerNombre = nombre.split(' ')[0] || nombre;

    if(ini) ini.textContent = primerNombre.charAt(0).toUpperCase();
    if(grt) grt.innerHTML = `Bienvenidaaaaa, <span>${primerNombre}</span>`;
    initLuxRewards();
  }

  try {
    const u = JSON.parse(sessionStorage.getItem('taboada_user') || '{}');
    if (u.nombre) applyAuth(u.nombre);
  } catch {}

  // REGISTRO ÚNICO
  const formReg = document.getElementById('form-register') as HTMLFormElement;
  if(formReg) {
    formReg.addEventListener('submit', async(e) => {
      e.preventDefault();
      const n = (document.getElementById('reg-nombre') as HTMLInputElement).value.trim();
      const btn = formReg.querySelector('button')!;
      
      btn.textContent = 'REGISTRANDO...'; 
      btn.style.opacity = '0.7';
      
      await new Promise(r => setTimeout(r, 1000));
      
      sessionStorage.setItem('taboada_user', JSON.stringify({ nombre: n }));
      applyAuth(n);
      showToast('✦ Registro Exitoso');
    });
  }

  // -- REWARDS (AHORA EN TEMA CLARO) --
  function initLuxRewards() {
    let claimed = false;
    const cards = document.querySelectorAll('.rw-card-light');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        if(claimed || card.classList.contains('used')) return;
        claimed = true;
        
        const tag = card.querySelector('.lux-claim-tag') as HTMLElement;
        if(tag) {
          tag.textContent = 'ACTIVO'; 
          tag.style.background = 'var(--gold)'; 
          tag.style.color = '#fff';
        }
        card.setAttribute('style', 'background:#FDF9F5; border:2px solid var(--gold); border-radius:16px; padding:19px; text-align:left; display:flex; align-items:center; gap:20px;');

        cards.forEach(o => {
          if (o !== card) {
            o.classList.add('used');
            o.setAttribute('style', 'background:#FFFFFF; border:1px solid #EAD9C5; border-radius:16px; padding:20px; text-align:left; display:flex; align-items:center; gap:20px; opacity:0.4; filter:grayscale(1);');
            const ot = o.querySelector('.lux-claim-tag') as HTMLElement;
            if(ot) ot.style.display = 'none';
          }
        });
        showToast('✦ Beneficio Seleccionado');
      });
    });
  }

  function showToast(msg: string) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-msg');
    if(!t || !m) return;
    m.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
  }
</script>
---
import AppLayout from '../../layouts/AppLayout.astro';

const combos = [
  { id:'c1', name:'Combo Familiar',     desc:'2 bolsas trufas + caja galletas + 2 panes artesanales', price:'75', normal:'110', img:'/images/combo_familiar.png',  badge:'⭐ Más Popular' },
  { id:'c2', name:'Combo Goloso',       desc:'Trufas premium + galletas + pastelito gourmet',          price:'45', normal:'65',  img:'/images/combo_goloso.png',    badge:'🔥 Más Vendido' },
  { id:'c3', name:'Combo Regalo FEXCO', desc:'Surtido premium en caja decorativa especial FEXCO',     price:'95', normal:'140', img:'/images/combo_regalo.png',    badge:'🎁 Ed. Especial' },
];

const rewards = [
  { id:'trufa',     icon:'🍫', title:'1 Trufa Artesanal',  sub:'Gratis en tu visita', tag:'Popular',    tagBg:'#7B3F1E', desc:'Famosa trufa de chocolate belga, elaborada a mano.' },
  { id:'choco-neg', icon:'🍬', title:'1 Chocolate Negro',  sub:'Gratis en tu visita', tag:'Exclusivo',  tagBg:'#C0392B', desc:'Barra 70% cacao sin azúcar añadida. Solo miembros.' },
  { id:'cupon2',    icon:'🎫', title:'2% de Descuento',    sub:'Válido por 1 mes',    tag:'30 días',    tagBg:'#C4854A', desc:'Descuento del 2% en cualquier compra (30 días).' },
  { id:'cupon4',    icon:'⭐', title:'4% de Descuento',    sub:'Válido 2 semanas',    tag:'Más ahorro', tagBg:'#D4A853', desc:'Descuento especial en compras durante 2 semanas.' },
];

const sucursales = [
  { ciudad:'Cochabamba', color:'#D4A853', icon:'🏪', locales:[
    { nombre:'La Recoleta',  dir:'Av. Potosí, La Recoleta' },
    { nombre:'Heroínas',     dir:'Calle Heroínas, Centro' },
  ]},
  { ciudad:'La Paz', color:'#C4854A', icon:'🏙️', locales:[
    { nombre:'Calacoto',     dir:'Zona Calacoto, La Paz' },
  ]},
  { ciudad:'Bolivia · Supermercados', color:'#A07858', icon:'🛒', locales:[
    { nombre:'Ketal', dir:'' },
    { nombre:'Hipermaxi', dir:'' },
    { nombre:'Fidalga', dir:'' },
  ]},
];
---
<AppLayout title="Chocolates Taboada · FEXCO 2026">

<style is:global>
  /* ── Layout Base ── */
  body {
    background-color: var(--cream);
  }
  .content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }

  /* ── HEADER CLEAN ── */
  .mars-header {
    padding: 24px 0;
    position: relative;
    z-index: 10;
  }
  .header-logo {
    display: flex; align-items: center; gap: 12px;
    text-decoration: none; color: var(--choco);
  }
  .header-logo img { width: 42px; height: auto; mix-blend-mode: multiply; }
  .logo-text { font-family: var(--font); font-weight: 900; font-size: 24px; letter-spacing: -0.02em; }

  /* ── HERO MARS STYLE ── */
  .hero-mars {
    padding: 40px 0 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
  }
  .hero-content h1 {
    font-family: var(--font);
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--choco);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }
  .hero-content p {
    font-size: 16px;
    color: #6A4433;
    line-height: 1.6;
    max-width: 420px;
    font-weight: 500;
  }
  .hero-images {
    position: relative;
    height: 400px;
    display: none; /* hidden on small mobile */
  }
  @media (min-width: 600px) { .hero-images { display: block; } }
  
  .h-img-1 { position: absolute; top: 0; right: 40px; width: 220px; filter: drop-shadow(-10px 20px 30px rgba(59,26,10,0.25)); transform: rotate(15deg); }
  .h-img-2 { position: absolute; bottom: 0; left: 40px; width: 180px; filter: drop-shadow(10px 15px 25px rgba(59,26,10,0.2)); transform: rotate(-10deg); }

  /* ── ORGANIC DARK WAVE SECTIONS ── */
  .dark-wave-section {
    background-color: var(--choco);
    color: var(--cream);
    position: relative;
    padding: 80px 0;
    margin-top: 60px;
  }
  .dark-wave-section::before {
    content: ''; position: absolute; top: -50px; left: 0; right: 0; height: 100px;
    background: var(--choco);
    border-radius: 50% 50% 0 0 / 100px 100px 0 0;
  }
  .dark-wave-section::after {
    content: ''; position: absolute; bottom: -50px; left: 0; right: 0; height: 100px;
    background: var(--choco);
    border-radius: 0 0 50% 50% / 0 0 100px 100px;
  }

  /* ── ACCORDION (REGISTRATION / LOGIN) ── */
  .accordion-box {
    background: var(--cream);
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 20px;
    color: var(--choco);
    transition: all 0.3s ease;
  }
  .acc-header {
    padding: 24px 28px;
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer;
    background: var(--cream);
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .acc-header:hover { background: #F6ECE0; }
  .acc-title { font-size: 18px; font-weight: 800; display: flex; align-items: center; gap: 12px; }
  .acc-icon {
    width: 32px; height: 32px; border-radius: 50%; background: var(--choco); color: var(--white);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .accordion-box.is-open .acc-icon { transform: rotate(180deg); background: var(--choco-lt); }
  
  .acc-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: #FFFFFF;
  }
  .acc-inner { padding: 0 28px 30px; border-top: 1px solid #EAD9C5; margin-top: 10px; padding-top: 24px; }
  
  /* Fields customization for inline form */
  .inline-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .inline-field label { font-size: 13px; font-weight: 700; color: var(--choco-mid); }
  .inline-field input {
    width: 100%; padding: 14px 16px; border: 2px solid #EAD9C5; border-radius: 12px;
    background: #FDF9F5; font-family: var(--font); font-size: 15px; color: var(--choco); outline: none; box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .inline-field input:focus { border-color: var(--choco-mid); background: #FFFFFF; }

  /* ── REWARDS STATE (Unlocks in the same place) ── */
  #state-registered { display: none; }
  .is-auth #state-unregistered { display: none; }
  .is-auth #state-registered { display: block; }

  /* ── COMBOS (MINIMALIST WHITE) ── */
  .combos-mars {
    padding: 120px 0 80px; /* Space for the bottom wave of previous section */
    text-align: center;
  }
  .combos-mars h2 {
    font-family: var(--font); font-weight: 900; font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--choco); margin-bottom: 50px; letter-spacing: -0.02em;
  }
  
  .min-card {
    background: var(--white);
    border-radius: 24px;
    padding: 30px;
    text-align: left;
    position: relative;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 10px 30px rgba(59,26,10,0.03);
  }
  .min-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(59,26,10,0.08); }
  
  .mc-img-wrap {
    height: 200px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
    background: #FDF9F5;
    border-radius: 16px;
    position: relative;
  }
  .mc-img-wrap img { max-height: 160px; object-fit: contain; filter: drop-shadow(0 15px 25px rgba(59,26,10,0.15)); }
  .mc-heart {
    position: absolute; top: 12px; right: 12px;
    width: 36px; height: 36px; border-radius: 50%; background: #FFFFFF;
    display: flex; align-items: center; justify-content: center;
    color: #BDC3C7; font-size: 18px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    cursor: pointer; transition: color 0.2s;
  }
  .mc-heart:hover { color: var(--red); }
  
  .mc-title { font-size: 20px; font-weight: 800; color: var(--choco); margin-bottom: 8px; }
  .mc-desc { font-size: 13px; color: var(--choco-lt); line-height: 1.5; margin-bottom: 24px; min-height: 40px; }
  
  .mc-bottom { display: flex; align-items: center; justify-content: space-between; }
  .mc-price { font-size: 24px; font-weight: 900; color: var(--choco); }
  .mc-old-price { font-size: 13px; color: #A07858; text-decoration: line-through; margin-left: 8px; font-weight: 600; }
  .mc-add {
    width: 44px; height: 44px; border-radius: 50%; background: var(--white);
    border: 2px solid #EAD9C5; color: var(--choco); font-size: 24px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s;
  }
  .mc-add:hover { background: var(--choco); color: var(--white); border-color: var(--choco); }

  /* ── SUCURSALES (In Dark Wave) ── */
  .suc-grid-mars { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 40px; }
  @media(min-width: 800px) { .suc-grid-mars { grid-template-columns: repeat(3, 1fr); } }

  /* ── Utilities ── */
  .badge-tag {
    position: absolute; top: 12px; left: 12px;
    background: var(--choco); color: var(--white); font-size: 10px; font-weight: 800;
    padding: 6px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em;
    z-index: 2;
  }
</style>

<div id="page-root">
  
  <!-- 1. HEADER LOGO -->
  <header class="content-wrapper mars-header">
    <a href="/" class="header-logo">
      <img src="/images/taboada-logo.png" alt="Logo" />
      <span class="logo-text">Chocolates Taboada</span>
    </a>
  </header>

  <!-- 2. HERO -->
  <section class="hero-mars content-wrapper">
    <div class="hero-grid">
      <div class="hero-content fu fu1">
        <h1>El chocolate<br/>es felicidad</h1>
        <p>15 años de tradición elaborando confitería a mano con los mejores ingredientes de Bolivia. Ven a FEXCO 2026 y llévate un dulce recuerdo.</p>
        <button class="btn btn-dark" style="margin-top: 32px;" onclick="document.getElementById('comunidad').scrollIntoView({behavior:'smooth'})">Explorar Beneficios</button>
      </div>
      <div class="hero-images fu fu3">
        <img src="/images/hero_truffle_box.png" alt="Trufas" class="h-img-1 float1" />
        <img src="/images/hero_croissant.png" alt="Pan" class="h-img-2 float2" />
        <!-- Floating dots/shapes a la Mars -->
        <div style="position:absolute; top:20%; left:20%; font-size:24px;" class="float2">✨</div>
        <div style="position:absolute; bottom:30%; right:10%; font-size:32px;" class="float1">🤎</div>
      </div>
    </div>
  </section>

  <!-- 3. ZONA COMUNIDAD (Registro/Recompensas) EN ONDA OSCURA -->
  <section class="dark-wave-section" id="comunidad">
    <div class="content-wrapper">
      
      <div style="text-align: center; margin-bottom: 40px; position:relative; z-index:2;">
        <h2 style="font-family:var(--font); font-size:clamp(2rem, 4.5vw, 3.5rem); font-weight:900; letter-spacing:-0.02em;">Tu Comunidad Exclusiva</h2>
        <p style="font-size:16px; color:rgba(253,248,242,0.8); max-width:500px; margin:10px auto 0;">Únete sin costo y desbloquea productos gratis, descuentos y la credencial vitalicia.</p>
      </div>

      <!-- ESTADO 1: NO REGISTRADO (Acordeones in-line) -->
      <div id="state-unregistered" style="max-width: 600px; margin: 0 auto; position:relative; z-index:2;">
        
        <!-- Accordion 1: Registro -->
        <div class="accordion-box" id="acc-reg">
          <div class="acc-header" onclick="toggleAcc('reg')">
            <div class="acc-title"><span style="font-size:20px;">✨</span> Crear cuenta y asegurar beneficios</div>
            <div class="acc-icon">↓</div>
          </div>
          <div class="acc-content" id="content-reg">
            <div class="acc-inner">
              <form id="form-register" style="display:flex;flex-direction:column;">
                <div class="grid-2">
                  <div class="inline-field"><label>Nombre</label><input type="text" id="reg-nombre" required /></div>
                  <div class="inline-field"><label>Apellido</label><input type="text" id="reg-apellido" required /></div>
                </div>
                <div class="inline-field"><label>Correo electrónico</label><input type="email" id="reg-correo" required /></div>
                <div class="inline-field">
                  <label>WhatsApp</label>
                  <div style="display:flex;gap:10px;">
                    <div style="background:#FDF9F5;border:2px solid #EAD9C5;border-radius:12px;padding:14px;color:var(--choco-lt);font-weight:700;display:flex;align-items:center;">+591</div>
                    <input type="tel" id="reg-wpp" style="flex:1;" required />
                  </div>
                </div>
                <!-- CAMPO CONTRASEÑA SOLICITADO -->
                <div class="inline-field"><label>Contraseña</label><input type="password" id="reg-pass" required placeholder="Crea una contraseña segura" /></div>
                
                <p id="reg-err" style="color:var(--red);font-size:13px;font-weight:700;display:none;margin:8px 0;text-align:center;"></p>
                <button type="submit" class="btn btn-dark" style="margin-top:16px;width:100%;padding:18px;">🔓 Registrarme y Desbloquear</button>
              </form>
            </div>
          </div>
        </div>

        <!-- Accordion 2: Login -->
        <div class="accordion-box" id="acc-log">
          <div class="acc-header" onclick="toggleAcc('log')">
            <div class="acc-title"><span style="font-size:20px;">👤</span> Ya tengo cuenta (Iniciar Sesión)</div>
            <div class="acc-icon">↓</div>
          </div>
          <div class="acc-content" id="content-log">
            <div class="acc-inner">
              <form id="form-login" style="display:flex;flex-direction:column;">
                <div class="inline-field"><label>Correo electrónico</label><input type="email" id="log-correo" required /></div>
                <!-- CAMPO CONTRASEÑA EN LOGIN -->
                <div class="inline-field"><label>Contraseña</label><input type="password" id="log-pass" required /></div>
                
                <p id="log-err" style="color:var(--red);font-size:13px;font-weight:700;display:none;margin:8px 0;text-align:center;"></p>
                <button type="submit" class="btn btn-dark" style="margin-top:16px;width:100%;padding:18px;">Entrar a mi cuenta</button>
              </form>
            </div>
          </div>
        </div>

      </div>

      <!-- ESTADO 2: REGISTRADO (Recompensas In-Line) -->
      <div id="state-registered" style="position:relative; z-index:2;">
        <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:24px; padding:32px; backdrop-filter:blur(10px);">
          
          <div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:24px;">
            <div id="user-initial" style="width:64px;height:64px;border-radius:50%;background:var(--cream);color:var(--choco);font-size:28px;font-weight:900;display:flex;align-items:center;justify-content:center;">M</div>
            <div>
              <div style="font-size:12px;color:var(--gold);text-transform:uppercase;font-weight:800;letter-spacing:0.1em;margin-bottom:4px;">Miembro Activo</div>
              <div id="user-greeting" style="font-family:var(--font);font-size:28px;font-weight:900;color:var(--cream);">¡Hola, María!</div>
            </div>
          </div>

          <h3 style="font-size:20px;font-weight:800;color:var(--cream);margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;">
             <span>Elige tu recompensa de hoy</span>
             <span id="rw-status-mars" style="font-size:12px;background:rgba(255,255,255,0.1);padding:6px 12px;border-radius:20px;">Elige 1 beneficio</span>
          </h3>

          <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(240px, 1fr));gap:16px;">
            {rewards.map(r => (
              <div class="card rw-card-mars" style="padding:20px;background:var(--white);color:var(--choco);border:none;cursor:pointer;position:relative;" data-id={r.id}>
                <span class="badge-tag" style={`background:${r.tagBg};`}>{r.tag}</span>
                <div style="font-size:32px;margin-top:24px;margin-bottom:12px;">{r.icon}</div>
                <div style="font-size:17px;font-weight:900;margin-bottom:4px;">{r.title}</div>
                <div style="font-size:12px;color:var(--choco-lt);font-weight:700;margin-bottom:20px;">{r.desc}</div>
                <button class="btn btn-dark btn-full btn-claim-mars" type="button" style="padding:12px;font-size:14px;">Reclamar</button>
                
                <div class="rw-overlay-mars" style="display:none;position:absolute;inset:0;background:rgba(39,174,96,0.95);border-radius:18px;flex-direction:column;align-items:center;justify-content:center;color:white;z-index:10;">
                  <span style="font-size:40px;">✅</span><span style="font-weight:900;margin-top:8px;">Canjeado</span><span style="font-size:11px;opacity:0.8;">Lista para ti</span>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- 4. COMBOS FEXCO (Fondo Crema, Tarjetas Blancas sin bordes) -->
  <section class="combos-mars content-wrapper">
    <h2>Los favoritos<br/>para la familia</h2>
    
    <div class="combos-grid" style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:30px;">
      {combos.map(c => (
        <div class="min-card">
          <span class="badge-tag">{c.badge}</span>
          <div class="mc-img-wrap">
            <div class="mc-heart">♡</div>
            <img src={c.img} alt={c.name} />
          </div>
          <div class="mc-title">{c.name}</div>
          <div class="mc-desc">{c.desc}</div>
          <div class="mc-bottom">
            <div>
              <span class="mc-price">Bs. {c.price}</span>
              <span class="mc-old-price">Bs. {c.normal}</span>
            </div>
            <button class="mc-add">+</button>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 5. SUCURSALES (Otra onda oscura como en el boceto) -->
  <section class="dark-wave-section" style="padding-bottom:120px;">
    <div class="content-wrapper">
      <h2 style="font-family:var(--font); font-size:clamp(2rem, 4vw, 3.5rem); font-weight:900; text-align:center; margin-bottom: 20px;">Disfruta Taboada<br/>Todo El Año</h2>
      
      <div class="suc-grid-mars">
        {sucursales.map(s => (
          <div style="background:rgba(255,255,255,0.05); border-radius:30px; padding:32px;">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
               <div style={`width:40px;height:40px;border-radius:50%;background:${s.color};display:flex;align-items:center;justify-content:center;font-size:20px;`}>{s.icon}</div>
               <div style="font-size:16px;font-weight:900;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">{s.ciudad}</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:20px;">
              {s.locales.map(l => (
                <div>
                  <div style="font-size:18px;font-weight:800;color:var(--cream);margin-bottom:4px;">{l.nombre}</div>
                  {l.dir && <div style="font-size:13px;color:rgba(253,248,242,0.6);">{l.dir}</div>}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</div>

<div class="toast" id="toast"><span id="toast-msg"></span></div>

</AppLayout>

<script>
  const root = document.getElementById('page-root')!;
  
  // -- ACCORDION LOGIC --
  const accordions = {
    reg: { box: document.getElementById('acc-reg')!, content: document.getElementById('content-reg')! },
    log: { box: document.getElementById('acc-log')!, content: document.getElementById('content-log')! }
  };

  (window as any).toggleAcc = function(key: 'reg' | 'log') {
    const isCurrentlyOpen = accordions[key].box.classList.contains('is-open');
    
    // Close all first
    Object.values(accordions).forEach(acc => {
      acc.box.classList.remove('is-open');
      acc.content.style.maxHeight = '0px';
    });

    // Open target if it wasn't open
    if (!isCurrentlyOpen) {
      accordions[key].box.classList.add('is-open');
      accordions[key].content.style.maxHeight = accordions[key].content.scrollHeight + "px";
    }
  };

  // Open Registration by default on load for UX
  setTimeout(() => { if(document.getElementById('acc-reg')) (window as any).toggleAcc('reg'); }, 500);


  // -- AUTH FLOW --
  function applyAuth(nombre: string) {
    root.classList.add('is-auth');
    const ini = document.getElementById('user-initial');
    const grt = document.getElementById('user-greeting');
    if(ini) ini.textContent = nombre.charAt(0).toUpperCase();
    if(grt) grt.textContent = `¡Hola, ${nombre}!`;
    initMarsRewards();
  }

  // Comprobar sesión al cargar
  try {
    const u = JSON.parse(sessionStorage.getItem('taboada_user') || '{}');
    if (u.nombre) applyAuth(u.nombre);
  } catch {}

  // REGISTER
  const formReg = document.getElementById('form-register') as HTMLFormElement;
  if(formReg) {
    formReg.addEventListener('submit', async(e) => {
      e.preventDefault();
      const n = (document.getElementById('reg-nombre') as HTMLInputElement).value.trim();
      const p = (document.getElementById('reg-pass') as HTMLInputElement).value.trim();
      
      if(!n || !p) return;
      const btn = formReg.querySelector('button')!;
      btn.textContent = 'Procesando...'; btn.disabled = true;
      
      await new Promise(r => setTimeout(r, 800));
      sessionStorage.setItem('taboada_user', JSON.stringify({ nombre: n }));
      applyAuth(n);
      showToast('🎉 Cuenta creada');
    });
  }

  // LOGIN
  const formLog = document.getElementById('form-login') as HTMLFormElement;
  if(formLog) {
    formLog.addEventListener('submit', async(e) => {
      e.preventDefault();
      const email = (document.getElementById('log-correo') as HTMLInputElement).value.trim();
      const pass = (document.getElementById('log-pass') as HTMLInputElement).value.trim();
      
      if(!email || !pass) return;
      const btn = formLog.querySelector('button')!;
      btn.textContent = 'Verificando...'; btn.disabled = true;
      
      await new Promise(r => setTimeout(r, 800));
      
      // Mock name from email
      const mock = email.split('@')[0].replace(/[^a-zA-Z]/g, '') || 'Miembro';
      const cap = mock.charAt(0).toUpperCase() + mock.slice(1);
      
      sessionStorage.setItem('taboada_user', JSON.stringify({ nombre: cap }));
      applyAuth(cap);
      showToast('👋 ¡De vuelta!');
    });
  }

  // -- REWARDS LOGIC --
  function initMarsRewards() {
    let claimed = false;
    const cards = document.querySelectorAll('.rw-card-mars');
    const st = document.getElementById('rw-status-mars');

    cards.forEach(card => {
      const btn = card.querySelector('.btn-claim-mars') as HTMLElement;
      const ov = card.querySelector('.rw-overlay-mars') as HTMLElement;

      if(!btn) return;

      const act = (e: Event) => {
        e.stopPropagation();
        if(claimed || card.classList.contains('locked')) return;
        
        claimed = true;
        ov.style.display = 'flex';
        
        cards.forEach(o => {
          if (o !== card) {
            o.classList.add('locked');
            o.style.opacity = '0.5';
            o.style.cursor = 'not-allowed';
            const ob = o.querySelector('.btn-claim-mars') as HTMLElement;
            if(ob) ob.textContent = 'Bloqueado';
          }
        });

        if(st) {
          st.textContent = 'Beneficio guardado ✅';
          st.style.color = '#27AE60';
          st.style.background = 'rgba(39, 174, 96, 0.2)';
        }
        showToast('🎟️ Beneficio asegurado');
      };

      btn.addEventListener('click', act);
      card.addEventListener('click', (e)=>{ if(!(e.target as HTMLElement).closest('.btn')) act(e); });
    });
  }

  // -- MISC UX --
  function showToast(msg: string) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-msg');
    if(!t || !m) return;
    m.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
  }
</script>

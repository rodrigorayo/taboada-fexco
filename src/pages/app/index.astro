---
import AppLayout from '../../layouts/AppLayout.astro';

const combos = [
  { id:'c1', name:'Combo Familiar',     desc:'2 bolsas de trufas belgas + selecta caja de galletas + 2 panes artesanales de masa madre', price:'75', normal:'110', img:'/images/combo_familiar.png', badge:'Preferido' },
  { id:'c2', name:'Combo Goloso',       desc:'Edición de trufas premium + galletas gourmet + pastelito artesanal', price:'45', normal:'65', img:'/images/combo_goloso.png', badge:'Más Vendido' },
  { id:'c3', name:'Combo Regalo FEXCO', desc:'Exclusivo surtido en elegante caja decorativa (Edición Limitada)', price:'95', normal:'140', img:'/images/combo_regalo.png', badge:'Edición Limitada' },
];

const rewards = [
  { id:'trufa',     icon:'✧', title:'Trufa Artesanal', sub:'Obsequio de bienvenida', tag:'Popular',   desc:'Degustación gratuita de nuestra emblemática trufa belga.' },
  { id:'choco-neg', icon:'✧', title:'Chocolate Negro', sub:'Obsequio exclusivo',     tag:'Premium',   desc:'Barra 70% cacao sin azúcar. Exclusivo para miembros.' },
  { id:'cupon2',    icon:'✧', title:'2% Off Black',    sub:'Beneficio mensual',      tag:'Beneficio', desc:'Descuento especial aplicable a todas sus compras x 30 días.' },
];

const sucursales = [
  { ciudad: 'Cochabamba', locales: [
    { nombre: 'Boutique La Recoleta', dir: 'Av. Potosí, Zona La Recoleta' },
    { nombre: 'Punto Heroínas',       dir: 'Calle Heroínas, Centro Histórico' },
  ]},
  { ciudad: 'La Paz', locales: [
    { nombre: 'Boutique Calacoto', dir: 'Zona Calacoto, Calle 15' },
  ]},
];
---
<AppLayout title="Chocolates Taboada · FEXCO 2026">

<style is:global>
  :root {
    --oro-viejo: #C4A77D;
    --beige-seda: #FDF5E6;
    --cafe-profundo: #1A0D0A;
  }

  body { background-color: var(--cafe-profundo); color: var(--beige-seda); margin: 0; }

  .fixed-header {
    position: fixed; top: 0; left: 0; width: 100%;
    padding: 10px 5%; display: flex; justify-content: space-between; align-items: center;
    z-index: 100; background-color: var(--cafe-profundo);
    border-bottom: 1px solid rgba(196,167,125,0.3);
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }
  .logo-main  { height: clamp(30px, 4vw, 45px); filter: brightness(0) invert(1); }
  .logo-fexco { height: clamp(18px, 3vw, 25px); opacity: 0.9; }

  .hero-landing {
    position: relative; min-height: 100vh;
    display: flex; align-items: center;
    background-color: var(--cafe-profundo); overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, rgba(26,13,10,0.95) 0%, rgba(26,13,10,0.8) 50%, rgba(26,13,10,0.6) 100%),
      url('/images/hero_truffle_box.png') center/cover no-repeat;
    z-index: 0;
  }
  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    padding: 100px 24px 60px;
    display: grid; grid-template-columns: 1fr;
    gap: 30px; width: 100%; align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-inner { grid-template-columns: 1.1fr 0.9fr; gap: 60px; padding: 120px 40px 60px; }
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 7vw, 4rem);
    color: var(--beige-seda); line-height: 1.1; margin-bottom: 15px;
  }
  .hero-title span { font-style: italic; font-weight: 400; color: #E0C9A6; }
  .hero-desc { color: rgba(253,245,230,0.85); max-width: 480px; font-size: clamp(14px,3vw,17px); line-height: 1.5; }

  .form-card {
    background: rgba(26,13,10,0.8); backdrop-filter: blur(12px);
    border: 1px solid rgba(196,167,125,0.3); border-radius: 20px;
    padding: 25px; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }
  .form-card h2 { color: var(--oro-viejo); font-family: var(--font-serif); font-size: 1.5rem; text-align: center; margin-bottom: 5px; }
  .form-card p  { color: #D7CCC8; font-size: 13px; text-align: center; margin-bottom: 20px; }
  .glass-field { margin-bottom: 12px; }
  .glass-field label { color: var(--oro-viejo); font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; display: block; }
  .glass-field input {
    background: rgba(255,255,255,0.08) !important; border: 1px solid rgba(196,167,125,0.2) !important;
    padding: 12px !important; color: #fff !important; border-radius: 8px !important; width: 100%; font-size: 14px;
  }
  .btn-register {
    width: 100%; padding: 15px; background: linear-gradient(135deg, var(--oro-viejo), #A68A64);
    color: #1A0D0A; font-weight: 900; border: none; border-radius: 10px; cursor: pointer; text-transform: uppercase; margin-top: 10px;
  }

  /* ── GALLERY ── */
  .gallery-section { padding: 100px 24px; background: var(--beige-seda); text-align: center; }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap: 30px; max-width: 1200px; margin: 40px auto 0; }
  .lux-card { background: white; padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); text-align: center; }
  .lux-card img { max-height: 180px; width: auto; margin-bottom: 20px; }
  .lux-card h3  { font-family: var(--font-serif); color: var(--cafe-profundo); font-size: 1.5rem; margin-bottom: 10px; }
  .lux-card p   { color: #5D4037; font-size: 0.9rem; line-height: 1.4; margin-bottom: 15px; }
  .lux-price { color: var(--oro-viejo); font-weight: 800; font-size: 1.4rem; }

  /* ── FOOTER ── */
  .footer-info { background: var(--cafe-profundo); padding: 80px 24px; color: var(--beige-seda); text-align: center; border-top: 1px solid rgba(196,167,125,0.2); }
  .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 40px; max-width: 1000px; margin: 0 auto 50px; }
  .footer-city  { color: var(--oro-viejo); text-transform: uppercase; letter-spacing: 0.2em; font-weight: 700; margin-bottom: 20px; font-size: 0.9rem; }
  .footer-local { margin-bottom: 15px; }
  .footer-local strong { display: block; font-family: var(--font-serif); font-size: 1.1rem; margin-bottom: 5px; }
  .footer-local span   { opacity: 0.7; font-size: 0.9rem; }
  .social-links { display: flex; justify-content: center; gap: 20px; }
  .social-links a { color: var(--oro-viejo); text-decoration: none; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; }
</style>

<div id="page-root">
  <div class="fixed-header">
    <img src="/images/taboada-logo-main.jpg" alt="Taboada" class="logo-main" />
    <img src="/images/fexco-logo-secondary.png" alt="FEXCO" class="logo-fexco" />
  </div>

  <section class="hero-landing">
    <div class="hero-bg"></div>
    <div class="hero-inner">
      <div class="hero-content">
        <span style="color:var(--oro-viejo);font-weight:700;letter-spacing:0.2em;font-size:11px;text-transform:uppercase;">Orgullo Boliviano en FEXCO</span>
        <h1 class="hero-title">El Sabor de<br/><span>Nuestra Historia</span></h1>
        <p class="hero-desc">Somos la primera fábrica de chocolates de Bolivia. Llevamos generaciones perfeccionando una receta familiar para ofrecerte el chocolate más exquisito.</p>
      </div>
      <div class="form-card">
        <h2>Únete a la Familia</h2>
        <p>Regístrate ahora y recibe regalos pensados para ti.</p>
        <form id="form-registro">
          <div class="glass-field">
            <label>Nombre Completo</label>
            <input type="text" id="reg-nombre" placeholder="Tu nombre" required />
          </div>
          <div class="glass-field">
            <label>Correo Electrónico</label>
            <input type="email" id="reg-correo" placeholder="ejemplo@gmail.com" required />
          </div>
          <div class="glass-field">
            <label>Número de WhatsApp</label>
            <input type="tel" id="reg-wpp" placeholder="70000000" required />
          </div>
          <button type="submit" class="btn-register">Registrarme ✦</button>
        </form>
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <h2 style="font-family:var(--font-serif);font-size:2.5rem;color:var(--cafe-profundo);margin-bottom:10px;">Colección FEXCO 2026</h2>
    <p style="color:#5D4037;margin-bottom:40px;">Ediciones limitadas disponibles solo en nuestro stand.</p>
    <div class="gallery-grid">
      {combos.map(c => (
        <div class="lux-card">
          <img src={c.img} alt={c.name} />
          <h3>{c.name}</h3>
          <p>{c.desc}</p>
          <div class="lux-price">Bs. {c.price}</div>
        </div>
      ))}
    </div>
  </section>

  <footer class="footer-info">
    <h2 style="font-family:var(--font-serif);font-size:2rem;margin-bottom:50px;">Nuestras Boutiques</h2>
    <div class="footer-grid">
      {sucursales.map(s => (
        <div>
          <div class="footer-city">{s.ciudad}</div>
          {s.locales.map(l => (
            <div class="footer-local">
              <strong>{l.nombre}</strong>
              <span>{l.dir}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
    <div class="social-links">
      <a href="#">FACEBOOK</a>
      <a href="#">INSTAGRAM</a>
      <a href="#">TIKTOK</a>
      <a href="#">WHATSAPP</a>
    </div>
    <p style="margin-top:60px;font-size:10px;opacity:0.4;letter-spacing:0.1em;">© 2026 CHOCOLATES TABOADA · DESDE 1903</p>
  </footer>
</div>

<script is:inline>
  var formReg = document.getElementById('form-registro');
  if (formReg) {
    formReg.addEventListener('submit', function(e) {
      e.preventDefault();
      var n = document.getElementById('reg-nombre').value.trim();
      var c = document.getElementById('reg-correo').value.trim();
      var w = document.getElementById('reg-wpp').value.trim();
      if (!n || !c || !w) return;
      sessionStorage.setItem('taboada_user', JSON.stringify({ nombre: n, correo: c, wpp: w }));
      window.location.href = '/beneficios';
    });
  }
</script>

</AppLayout>
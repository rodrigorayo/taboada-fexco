---

<AppLayout title="Chocolates Taboada · FEXCO 2026">

<style is:global>
  :root {
    --oro-viejo: #C4A77D;
    --beige-seda: #FDF5E6;
    --cafe-profundo: #1A0D0A;
    --font-serif: "Playfair Display", serif; 
  }

  /* ── Barra de Logos Fija ── */
  .fixed-header {
    position: fixed;
    top: 0; left: 0; width: 100%;
    padding: 10px 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    background-color: var(--cafe-profundo);
    border-bottom: 1px solid rgba(196, 167, 125, 0.3);
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    pointer-events: auto;
  }
  .fixed-header img { pointer-events: auto; }
  
  /* ── SECCIÓN 1: HERO & REGISTRO ── */
  .hero-landing {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--cafe-profundo);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background: 
      linear-gradient(135deg, rgba(26, 13, 10, 0.95) 0%, rgba(26, 13, 10, 0.8) 50%, rgba(26, 13, 10, 0.6) 100%),
      url('/images/port2.jpg') center/cover no-repeat;
    z-index: 0;
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    padding: 100px 24px 40px;
    display: grid; grid-template-columns: 1fr;
    gap: 30px; width: 100%;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner { grid-template-columns: 1.1fr 0.9fr; gap: 60px; padding: 120px 40px 0; }
  }

  .hero-title {
    font-family: var(--font-serif);
    /* AJUSTE DINÁMICO: 2.2rem en cel, hasta 4rem en PC */
    font-size: clamp(2.2rem, 8vw, 4rem); 
    color: var(--beige-seda); line-height: 1.1; margin-bottom: 15px;
  }
  .hero-title span { font-style: italic; font-weight: 400; color: #E0C9A6; }

  .hero-desc {
    color: rgba(253, 245, 230, 0.85); max-width: 480px; 
    font-size: clamp(14px, 4vw, 17px); line-height: 1.5;
  }

  .form-card {
    background: rgba(26, 13, 10, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(196, 167, 125, 0.3);
    border-radius: 20px;
    padding: clamp(20px, 5vw, 30px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .form-card h2 { color: var(--oro-viejo); font-family: var(--font-serif); font-size: 1.5rem; text-align: center; margin-bottom: 5px; }
  .form-card p { color: #D7CCC8; font-size: 13px; text-align: center; margin-bottom: 20px; }

  .glass-field { margin-bottom: 12px; }
  .glass-field label { color: var(--oro-viejo); font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; display: block; }
  .glass-field input {
    background: rgba(255, 255, 255, 0.08) !important; border: 1px solid rgba(196, 167, 125, 0.2) !important;
    padding: 12px !important; color: #fff !important; border-radius: 8px !important; width: 100%; font-size: 14px;
  }

  .btn-register {
    width: 100%; padding: 15px; background: linear-gradient(135deg, var(--oro-viejo), #A68A64);
    color: #1A0D0A; font-weight: 900; border: none; border-radius: 10px; cursor: pointer; text-transform: uppercase;
    margin-top: 10px;
  }
  /* AJUSTES ESPECÍFICOS PARA CELULAR */
  @media (max-width: 600px) {
    .hero-inner { padding-top: 80px; text-align: center; }
    .hero-desc { margin: 0 auto 20px; }
    .fixed-header { padding: 8px 4%; }
  }
</style>
<div id="page-root">
  <div class="fixed-header luxury-wrapper">
    <img 
      src="/images/taboada-logo.png" 
      alt="Taboada" 
      class="logo-main" 
      style="height: clamp(60px, 8vw, 160px); width: auto;" 
    />  
    <img 
      src="/images/fexco-logo.png" 
      alt="FEXCO" 
      class="logo-fexco" 
      style="height: clamp(20px, 5vw, 35px); width: auto;" 
    />
  </div>
  <section class="hero-landing">
    <div class="hero-bg"></div>
    <div class="hero-inner">
<div class="hero-content">
  <span style="color: var(--oro-viejo); font-weight: 700; letter-spacing: 0.2em; font-size: clamp(12px, 3vw, 16px); text-transform: uppercase;">
    Orgullo Boliviano en FEXCO
  </span>
  <h1 class="hero-title">
    <span style="font-size: clamp(2rem, 5vw, 1.8rem); color: var(--beige-seda); font-style: normal; font-weight: 400; display: block; line-height: 1.2; margin-bottom: 5px;">
      Se parte del sabor de
    </span>
    <span>Nuestra Historia</span>
  </h1>
  <p class="hero-desc" style="font-size: clamp(8px, 4vw, 17px); line-height: 1.4; color: rgba(253, 245, 230, 0.85); max-width: 480px;">
    Somos la primera fábrica de chocolates de Bolivia. Llevamos generaciones perfeccionando una receta familiar para ofrecerte el chocolate más exquisito.
  </p>
</div>
      <div class="form-card">
        <h2>Se parte de la Comunidad</h2>
        <p>Regístrate ahora y recibe regalos pensados para ti.</p>
        <form id="form-registro">
          <div class="glass-field">
            <label>Número de WhatsApp</label>
            <input type="tel" id="reg-wpp" placeholder="70000000" required />
          </div>
          <button type="submit" class="btn-register">Quiero mi regalo de bienvenida ✦</button>
        </form>
      </div>
    </div>
  </section>
</div>
<script>
  // Cambia esta variable de entorno en Vercel para que apunte a tu Backend en la nube
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';

  const form = document.getElementById('form-registro');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const wppInput = document.getElementById('reg-wpp');
    const whatsapp = wppInput ? wppInput.value : '';
    
    if(!whatsapp) return;

    const btn = form.querySelector('button');
    if(btn) {
      btn.innerText = "Conectando...";
      btn.disabled = true;
      btn.style.opacity = '0.7';
    }

    try {
      // 1. Guardar o verificar en el Sistema Central (Backend Python)
      const res = await fetch(`${API_URL}/comunidad/check-phone/${whatsapp}`);
      
      if (!res.ok) {
        throw new Error("Error en el backend");
      }
      
      const data = await res.json();

      // 2. Guardar en la sesión temporal para la siguiente página
      sessionStorage.setItem('taboada_user', JSON.stringify({ 
        whatsapp: whatsapp,
        ha_reclamado: data.ha_reclamado
      }));

      // 3. Redirigir
      window.location.href = '/beneficios';

    } catch (err) {
      console.error(err);
      alert("No pudimos conectar con el servidor central. Intenta de nuevo.");
      if(btn) {
        btn.innerText = "Quiero mi regalo de bienvenida ✦";
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    }
  });
</script>
</AppLayout>